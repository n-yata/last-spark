{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File '.codex\\hooks\\block-no-verify.ps1'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File '.codex\\hooks\\verify-git-worktree.ps1'",
            "statusMessage": "git状態を確認中..."
          }
        ]
      }
    ]
  }
}
